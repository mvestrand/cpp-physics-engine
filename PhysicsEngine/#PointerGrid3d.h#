#pragma once

#include <vector>
#include <list>

#define X_CHUNK_SIZE 64
#define Y_CHUNK_SIZE 64
#define Z_CHUNK_SIZE 16
#define X_MULTIPLIER (1.0 / X_CHUNK_SIZE)
#define Y_MULTIPLIER (1.0 / Y_CHUNK_SIZE)
#define Z_MULTIPLIER (1.0 / Z_CHUNK_SIZE)

template <class T>
class PointerGridChunk3d {
	T contents[X_CHUNK_SIZE][Y_CHUNK_SIZE][Z_CHUNK_SIZE];


public:
	int count = 0;

	PointerGridChunk3d() {
	  for (int i = 0; i < X_CHUNK_SIZE; i++) {
	    for (int j = 0; j < Y_CHUNK_SIZE; j++) {
	      for (int k = 0; k < Z_CHUNK_SIZE; k++) {
		contents[i][j][k] = NULL;
	      }
	    }
	  }
	}

	inline void set(int x, int y, int z, T val) {
	  if (contents[x][y][z] == NULL) {
	    if (val != NULL) {
	      count++;
	      contents[x][y][z] = val;
	    }
	  }
	  else {
	    if (val == NULL) {
	      count--;
	      contents[x][y][z] = NULL;
	    }
	    else {
	      contents[x][y][z] = val;
	    }
	  }
	}
	inline T get(int x, int y, int z) {
		return contents[x][y][z];
	}

	static PointerGridChunk3d<T> *newChunk() {
		if (objPool.size() == 0) {
			return new PointerGridChunk3d<T>;
		}
		else {
			PointerGridChunk3d<T> *tmp = objPool.front();
			objPool.pop_front();
			if (tmp->count > 0) {
				for (int i = 0; i < X_CHUNK_SIZE; i++) {
					for (int j = 0; j < Y_CHUNK_SIZE; j++) {
						for (int k = 0; k < Z_CHUNK_SIZE; k++) {
							tmp->contents[i][j] = NULL;
						}
					}
				}
			}
			return tmp;
		}
	}
	static void deleteChunk(PointerGridChunk3d<T> *ptr) {
		objPool.push_back(ptr);
	}
	static void deletePool() {
		while (!objPool.empty()) {
			delete objPool.front();
			objPool.pop_front();
		}
	}
	static std::list<PointerGridChunk3d<T>*> objPool;
};

template <class T> std::list<PointerGridChunk3d<T>*> PointerGridChunk3d<T>::objPool;


template <class T>
class PointerGrid3d
{

public:
	struct chunk_vector_pair {
		std::vector<PointerGridChunk3d<T>*> positive; // 0...n
		std::vector<PointerGridChunk3d<T>*> negative; // -1...-n
	};
	struct vector_pair {
		std::vector<chunk_vector_pair> positive;
		std::vector<chunk_vector_pair> negative;
	};

	PointerGrid3d();
	~PointerGrid3d();

	std::vector<vector_pair> positive;
	std::vector<vector_pair> negative;

	T get(int x, int y, int z);
	void set(int x, int y, int z, T val);
};

template <class T>
PointerGrid3d<T>::PointerGrid3d() {}

template <class T>
PointerGrid3d<T>::~PointerGrid3d()
{
	for (vector_pair pair1 : positive) {
		for (chunk_vector_pair pair2 : pair1.positive) {
			for (PointerGridChunk3d<T> *chunk : pair2.positive) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
			for (PointerGridChunk3d<T> *chunk : pair2.negative) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
		}
		for (chunk_vector_pair pair2 : pair1.negative) {
			for (PointerGridChunk3d<T> *chunk : pair2.positive) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
			for (PointerGridChunk3d<T> *chunk : pair2.negative) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
		}
	}
	for (vector_pair pair1 : negative) {
		for (chunk_vector_pair pair2 : pair1.positive) {
			for (PointerGridChunk3d<T> *chunk : pair2.positive) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
			for (PointerGridChunk3d<T> *chunk : pair2.negative) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
		}
		for (chunk_vector_pair pair2 : pair1.negative) {
			for (PointerGridChunk3d<T> *chunk : pair2.positive) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
			for (PointerGridChunk3d<T> *chunk : pair2.negative) {
				if (chunk != NULL) {
					PointerGridChunk3d<T>::deleteChunk(chunk);
				}
			}
		}
	}

}

template <class T>
void PointerGrid3d<T>::set(int x, int y, int z, T val)
{
  int x_chunk = (int)floor(x * X_MULTIPLIER);
  int y_chunk = (int)floor(y * Y_MULTIPLIER);
  int z_chunk = (int)floor(z * Z_MULTIPLIER);
  int x_index = x % X_CHUNK_SIZE;
  int y_index = y % Y_CHUNK_SIZE;
  int z_index = z % Z_CHUNK_SIZE;
  
  if (x_chunk >= 0) { // Positive x
    if (x_chunk >= positive.size()) { // Resize x if necessary
      positive.resize(x_chunk + 1);
    }
    vector_pair &y_vectors = positive[x_chunk];
    
    // Positive y
    if (y_chunk >= 0) { 
      // Resize y if necessary
      if (y_chunk >= y_vectors.positive.size()) { 
	y_vectors.positive.resize(y_chunk + 1, NULL);
      }
