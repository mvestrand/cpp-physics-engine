	  z_vectors.positive.resize(z_chunk + 1, NULL);
	}
	
	// Allocate chunk if needed
	if (z_vectors.positive[z_chunk] == NULL) { 
	  z_vectors.positive[z_chunk] = PointerGridChunk3d<T>::newChunk();
	}
	
	// Set value
	z_vectors.positive[z_chunk]->set(x_index, y_index, z_index, val);
	
	// Release chunk if needed
	if (z_vectors.positive[z_chunk]->count == 0) { 
	  PointerGridChunk3d<T>::deleteChunk(z_vectors.positive[z_chunk]);
	  z_vectors.positive[z_chunk] = NULL;
	}
      }
      // Negative z
      else {
	z_chunk = -z_chunk - 1;
	
	// Resize z vector if necessary
	if (z_chunk >= z_vectors.negative.size()) {
					z_vectors.negative.resize(z_chunk + 1, NULL);
